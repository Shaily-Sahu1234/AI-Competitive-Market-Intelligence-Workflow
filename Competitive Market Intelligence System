    "# ==========================================\n",
    "# PHASE 3 — COMPETITIVE SCORING MODEL\n",
    "# ==========================================\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 5 — SEGMENT INNOVATION SCORE\n",
    "# ------------------------------------------\n",
    "\n",
    "print(\"📊 SEGMENT INNOVATION SCORE (Average AI Sophistication)\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "segment_innovation_score = (\n",
    "    df.groupby(\"Segment\")[\"AI_Score\"]\n",
    "    .mean()\n",
    "    .sort_values(ascending=False)\n",
    ")\n",
    "\n",
    "print(segment_innovation_score)\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 6 — STAGE SCORE MAPPING\n",
    "# ------------------------------------------\n",
    "\n",
    "stage_map = {\n",
    "    \"Very Early Stage\": 1,\n",
    "    \"Early Stage\": 2,\n",
    "    \"Early Growth\": 3,\n",
    "    \"Growth Stage\": 4,\n",
    "    \"Mature Stage\": 5,\n",
    "    \"Publicly Listed\": 6\n",
    "}\n",
    "\n",
    "df[\"Stage_Score\"] = df[\"Stage\"].map(stage_map)\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7 — B2B vs B2C CLASSIFICATION\n",
    "# ------------------------------------------\n",
    "# We classify based on Revenue_Model or Target_User\n",
    "\n",
    "def classify_business_model(row):\n",
    "    if \"B2B\" in row[\"Revenue_Model\"]:\n",
    "        return 3  # Strong enterprise positioning\n",
    "    elif \"subscription\" in row[\"Revenue_Model\"].lower() or \"consultation\" in row[\"Revenue_Model\"].lower():\n",
    "        return 2  # Consumer subscription / mixed\n",
    "    else:\n",
    "        return 1  # Low strategic scalability\n",
    "\n",
    "df[\"Business_Model_Score\"] = df.apply(classify_business_model, axis=1)\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 8 — FINAL COMPETITIVE STRENGTH SCORE\n",
    "# Weights:\n",
    "# AI Score → 40%\n",
    "# Stage Score → 30%\n",
    "# Business Model Score → 30%\n",
    "# ------------------------------------------\n",
    "\n",
    "df[\"Competitive_Score\"] = (\n",
    "    df[\"AI_Score\"] * 0.4 +\n",
    "    df[\"Stage_Score\"] * 0.3 +\n",
    "    df[\"Business_Model_Score\"] * 0.3\n",
    ")\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 9 — RANK COMPANIES\n",
    "# ------------------------------------------\n",
    "\n",
    "df_ranked = df.sort_values(\"Competitive_Score\", ascending=False)\n",
    "\n",
    "print(\"\\n\\n🏆 COMPETITIVE RANKING\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "print(df_ranked[[\n",
    "    \"Company\",\n",
    "    \"Segment\",\n",
    "    \"AI_Score\",\n",
    "    \"Stage_Score\",\n",
    "    \"Business_Model_Score\",\n",
    "    \"Competitive_Score\"\n",
    "]])\n",
    "\n",
    "print(\"\\n✅ Competitive Scoring Model Complete\")"
   ]
