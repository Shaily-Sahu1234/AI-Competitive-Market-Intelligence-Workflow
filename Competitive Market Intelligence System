    "# ==========================================\n",
    "# SIMPLE & STABLE LLM SETUP (NO SDK)\n",
    "# ==========================================\n",
    "\n",
    "import pandas as pd\n",
    "import requests\n",
    "import json\n",
    "\n",
    "# ------------------------------\n",
    "# LOAD DATASET\n",
    "# ------------------------------\n",
    "\n",
    "df = pd.read_csv(\"ai_healthcare_competitive_intelligence_india_updated.csv\")\n",
    "\n",
    "# ------------------------------\n",
    "# ADD AI & STAGE SCORES\n",
    "# ------------------------------\n",
    "\n",
    "intensity_map = {\n",
    "    \"High\": 3,\n",
    "    \"Medium\": 2,\n",
    "    \"Low-Medium\": 1.5\n",
    "}\n",
    "\n",
    "stage_map = {\n",
    "    \"Very Early Stage\": 1,\n",
    "    \"Early Stage\": 2,\n",
    "    \"Early Growth\": 3,\n",
    "    \"Growth Stage\": 4,\n",
    "    \"Mature Stage\": 5,\n",
    "    \"Publicly Listed\": 6\n",
    "}\n",
    "\n",
    "df[\"AI_Score\"] = df[\"AI_Intensity\"].map(intensity_map)\n",
    "df[\"Stage_Score\"] = df[\"Stage\"].map(stage_map)\n",
    "\n",
    "# ------------------------------\n",
    "# API CONFIG\n",
    "# ------------------------------\n",
    "\n",
    "API_KEY = \"YOUR_API_KEY\"\n",
    "\n",
    "def call_llm(prompt):\n",
    "    url = \"https://api.openai.com/v1/chat/completions\"\n",
    "    \n",
    "    headers = {\n",
    "        \"Authorization\": f\"Bearer {API_KEY}\",\n",
    "        \"Content-Type\": \"application/json\"\n",
    "    }\n",
    "\n",
    "    data = {\n",
    "        \"model\": \"gpt-4o-mini\",\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n",
    "        \"temperature\": 0.7\n",
    "    }\n",
    "\n",
    "    response = requests.post(url, headers=headers, data=json.dumps(data))\n",
    "    \n",
    "    if response.status_code != 200:\n",
    "        print(\"Error:\", response.text)\n",
    "        return None\n",
    "\n",
    "    return response.json()[\"choices\"][0][\"message\"][\"content\"]\n",
    "\n",
    "# ------------------------------\n",
    "# SWOT FUNCTION\n",
    "# ------------------------------\n",
    "\n",
    "def generate_swot(row):\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "    You are a healthcare strategy analyst.\n",
    "\n",
    "    Analyze this startup:\n",
    "\n",
    "    Company: {row['Company']}\n",
    "    Segment: {row['Segment']}\n",
    "    AI Type: {row['AI_Type']}\n",
    "    Target User: {row['Target_User']}\n",
