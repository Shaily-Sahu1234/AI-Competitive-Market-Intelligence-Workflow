    "# ==========================================\n",
    "# PHASE 4 — WHITE SPACE DETECTION\n",
    "# ==========================================\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "print(\"🔍 WHITE SPACE DETECTION ANALYSIS\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7A — Segment Company Count\n",
    "# ------------------------------------------\n",
    "\n",
    "segment_counts = df.groupby(\"Segment\").size()\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7B — Average AI Score per Segment\n",
    "# ------------------------------------------\n",
    "\n",
    "avg_ai_score = df.groupby(\"Segment\")[\"AI_Score\"].mean()\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7C — Early Stage Dominance\n",
    "# Count companies in early stages\n",
    "# ------------------------------------------\n",
    "\n",
    "early_stages = [\"Very Early Stage\", \"Early Stage\", \"Early Growth\"]\n",
    "\n",
    "early_stage_counts = (\n",
    "    df[df[\"Stage\"].isin(early_stages)]\n",
    "    .groupby(\"Segment\")\n",
    "    .size()\n",
    ")\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7D — Combine All Metrics\n",
    "# ------------------------------------------\n",
    "\n",
    "white_space_df = pd.DataFrame({\n",
    "    \"Company_Count\": segment_counts,\n",
    "    \"Average_AI_Score\": avg_ai_score,\n",
    "    \"Early_Stage_Count\": early_stage_counts\n",
    "}).fillna(0)\n",
    "\n",
    "white_space_df[\"Early_Stage_Ratio\"] = (\n",
    "    white_space_df[\"Early_Stage_Count\"] / white_space_df[\"Company_Count\"]\n",
    ")\n",
    "\n",
    "white_space_df = white_space_df.sort_values(\"Company_Count\")\n",
    "\n",
    "print(\"\\n📊 SEGMENT WHITE SPACE SUMMARY\")\n",
    "print(white_space_df)\n",
    "\n",
    "# ------------------------------------------\n",
    "# STEP 7E — Identify Potential White Space\n",
    "# Criteria:\n",
    "# Low Company_Count (<=2)\n",
    "# High Average_AI_Score (>=2.5)\n",
    "# ------------------------------------------\n",
    "\n",
    "white_space_candidates = white_space_df[\n",
    "    (white_space_df[\"Company_Count\"] <= 2) &\n",
    "    (white_space_df[\"Average_AI_Score\"] >= 2.5)\n",
    "]\n",
    "\n",
    "print(\"\\n🚀 POTENTIAL WHITE SPACE SEGMENTS\")\n",
    "print(white_space_candidates)\n",
    "\n",
    "# ==========================================\n",
    "# STEP 8 — SEGMENT DISTRIBUTION VISUALIZATION\n",
    "# ==========================================\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "segment_counts.sort_values().plot(kind=\"bar\")\n",
    "\n",
    "plt.title(\"AI Healthcare Segment Distribution (Competitive Density)\")\n",
    "plt.xlabel(\"Segment\")\n",
    "plt.ylabel(\"Number of Companies\")\n",
    "plt.xticks(rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ==========================================\n",
    "# OPTIONAL — AI Sophistication Heatmap\n",
    "# ==========================================\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "sns.heatmap(\n",
    "    white_space_df[[\"Company_Count\", \"Average_AI_Score\"]],\n",
    "    annot=True,\n",
    "    cmap=\"YlOrRd\"\n",
    ")\n",
    "\n",
    "plt.title(\"Segment Competitive & Innovation Heatmap\")\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✅ White Space Detection Complete\")"
   ]
